{
  "enabledPlugins": {
    "impeccable@impeccable": true,
    "frontend-design@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  },
  "permissions": {
    "allow": [
      "Bash(make backend-test)",
      "Bash(make backend-run)",
      "Bash(make frontend-dev)",
      "Bash(make up-dev)",
      "Bash(make down-dev)",
      "Bash(cd backend && go build ./...)",
      "Bash(cd backend && go vet ./...)",
      "Bash(cd frontend && npx tsc --noEmit)",
      "Bash(cd frontend && npx vite build)",
      "Bash(cd frontend && npm install)",
      "Bash(cd backend && go mod tidy)"
    ]
  }
}
